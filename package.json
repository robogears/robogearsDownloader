{
  "name": "robogears-downloader",
  "version": "0.1.30",
  "description": "Desktop app for downloading lossless FLAC tracks from TIDAL via TIDAL/Spotify URLs, search, or screenshot OCR.",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "auth": "node tidal_auth_node.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac --arm64",
    "sync-ext": "node scripts/sync-extension-version.js"
  },
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robogears/robogearsDownloader.git"
  },
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "music-metadata": "^7.14.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.robogears.downloader",
    "productName": "robogears Downloader",
    "copyright": "Copyright © 2026 robogears",
    "publish": null,
    "afterPack": "./build/after-pack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "tidal_lib.js",
      "tidal_download.js",
      "tidal_auth_node.js",
      "tidal_search.js",
      "tidal_check_quality.js",
      "bulk_runner.js",
      "extension-server.js",
      "renderer/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/*.md",
      "!.gitignore",
      "!start_app.bat",
      "!**/{.DS_Store,Thumbs.db,desktop.ini}",
      "!**/{.git,.github,.vscode,.idea}",
      "!**/{*.log,*.tmp,token.json}"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": "chrome-extension/",
        "to": "chrome-extension/"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "robogears Downloader",
      "artifactName": "robogears-downloader-setup.exe",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.music",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "artifactName": "robogears-downloader-mac-${arch}.${ext}",
      "identity": null
    },
    "dmg": {
      "title": "Install robogears Downloader",
      "background": "build/dmg-background.png",
      "iconSize": 100,
      "window": {
        "width": 540,
        "height": 400
      },
      "contents": [
        { "x": 140, "y": 220, "type": "file" },
        { "x": 400, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
